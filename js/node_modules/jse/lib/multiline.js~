var __LINES__ = [];
(function() {
  var reader = require('readline').createInterface({
    input: process.stdin,
    output: function() {}
  });
  reader.on('line', function(line) {
    __LINES__.push(line);
  });
  process.stdin.on('end', function () {
    return eval(process.argv.slice(-1)[0]);
  });
})();
